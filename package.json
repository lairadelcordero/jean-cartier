{
  "name": "jean-cartier-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 777",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 777",
    "dev:turbo": "next dev --turbopack -p 777",
    "build": "next build",
    "build:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize:images": "node scripts/optimize-images.mjs",
    "promote:licenciatario": "node scripts/promote-licenciatario.mjs"
  },
  "dependencies": {
    "@mercadopago/sdk-js": "^0.0.3",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.43.0",
    "lucide-react": "^1.7.0",
    "mercadopago": "^2.12.0",
    "next": "^16.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
