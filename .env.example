NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# New Supabase dashboard keys (publishable) — or use legacy anon JWT below
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MERCADO_PAGO_PUBLIC_KEY=your-mp-public-key
MERCADO_PAGO_ACCESS_TOKEN=your-mp-access-token
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:777
# Canonical URL for SEO (include https:// — bare domains break metadataBase and cause HTTP 500)
NEXT_PUBLIC_SITE_URL=https://jeancartier.ar
# Optional search console verification meta tags
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
