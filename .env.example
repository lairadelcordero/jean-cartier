# ---------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# ---------------------------------------------------------------------------
# Auth redirects (development): Dashboard → Authentication → URL configuration
#   http://localhost:777/**
#   http://localhost:777/api/auth/callback
# Guía paso a paso (rol licenciatario, licencias): docs/guia-licenciatario-supabase.md
# ---------------------------------------------------------------------------
# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (Settings → API → Publishable key) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# Legacy anon public key (JWT) if not using publishable keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role — server-only; never expose to the browser (Settings → API → service_role)
# Usá la clave real para scripts locales (promote:*) y para APIs admin server-side (/api/admin/*)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Mercado Pago — https://www.mercadopago.com.ar/developers/panel/app
# ---------------------------------------------------------------------------
# Public key for client-side checkout (Credentials → Public Key)
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=your-mp-public-key
# Access token for server/API calls (Credentials → Access Token)
MERCADO_PAGO_ACCESS_TOKEN=your-mp-access-token

# ---------------------------------------------------------------------------
# App environment (REQ-1: use NEXT_PUBLIC_ENVIRONMENT; NEXT_PUBLIC_APP_ENV kept as fallback)
# ---------------------------------------------------------------------------
# development | staging | production — shown on hello-world and used where needed
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_APP_ENV=development
# Local dev URL (this repo uses port 777)
NEXT_PUBLIC_APP_URL=http://localhost:777
# Canonical site URL for SEO (production)
NEXT_PUBLIC_SITE_URL=https://jeancartier.ar

# ---------------------------------------------------------------------------
# Optional — Figma npm registry (private packages under @jean-cartier)
# ---------------------------------------------------------------------------
# Token from Figma → Make / design system → npm registry. npm/pnpm do not read
# .env for .npmrc; export before install, or put _authToken in ~/.npmrc locally.
FIGMA_NPM_TOKEN=

# ---------------------------------------------------------------------------
# Optional — Search Console verification meta tags
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
